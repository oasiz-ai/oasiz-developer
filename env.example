## Oasiz upload environment (copy to .env and fill in your email)
#
# Use your own Oasiz account email below.
# The API URL is shared.
# The upload token is shared internally by the Oasiz team; do not commit the real value.

OASIZ_EMAIL=you@example.com
OASIZ_API_URL=https://oasiz.gg/api/upload/game
OASIZ_UPLOAD_TOKEN=your_shared_upload_token
